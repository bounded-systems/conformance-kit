{
  "size": {
    "body": { "$type": "dimension", "$value": "16px" },
    "title": { "$type": "dimension", "$value": "20px" },
    "h2": { "$type": "dimension", "$value": "30px" }
  },
  "text": {
    "body": {
      "$type": "typography",
      "$value": { "fontSize": "{size.body}", "lineHeight": 1.5, "fontWeight": 400, "letterSpacing": "0" }
    },
    "title": {
      "$type": "typography",
      "$value": { "fontSize": "{size.title}", "lineHeight": 1.3, "fontWeight": 600, "letterSpacing": "-0.01em" }
    },
    "h2": {
      "$type": "typography",
      "$value": { "fontSize": "{size.h2}", "lineHeight": 1.1, "fontWeight": 700, "letterSpacing": "-0.02em" }
    }
  }
}
